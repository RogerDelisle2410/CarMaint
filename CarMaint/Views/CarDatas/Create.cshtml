@model CarMaint.Models.CarData
@using Newtonsoft.Json.Linq

@{
    string lang = "en";
    if (Request.Cookies["lang"] != null)
    {
        lang = Request.Cookies["lang"].Value;
    }

    JObject Lang;

    try
    {
        string jsonPath = Server.MapPath("~/Lang/" + lang + ".json");
        string jsonText = System.IO.File.ReadAllText(jsonPath);
        Lang = JObject.Parse(jsonText);
    }
    catch
    {
        string fallbackPath = Server.MapPath("~/Lang/en.json");
        string fallbackText = System.IO.File.ReadAllText(fallbackPath);
        Lang = JObject.Parse(fallbackText);
    }
}

<h2>@Lang["car_create_title"]</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <h4>@Lang["car_create_info"]</h4>
        <hr />

        @Html.ValidationSummary(true, "", new { @class = "text-danger inline-msg" })

        <!-- Customer -->
        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">@Lang["col_customer_name"]</label>
            <div class="col-sm-4 d-flex align-items-center">
                @Html.DropDownList("CustomerId", null, Lang["col_select_customer"].ToString(),
                    new { @class = "form-control fixed-input" })
                @Html.ValidationMessageFor(model => model.CustomerId, "", new { @class = "text-danger inline-msg" })
            </div>
        </div>

        <!-- Manufacturer -->
        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">@Lang["col_manufacturer"]</label>
            <div class="col-sm-4 d-flex align-items-center">
                @Html.DropDownListFor(model => model.Manufacturer,
                    (IEnumerable<SelectListItem>)ViewBag.ManufacturerList,
                    new { @class = "form-control fixed-input" })
                @Html.ValidationMessageFor(model => model.Manufacturer, "", new { @class = "text-danger inline-msg" })
            </div>
        </div>

        <!-- Model -->
        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">@Lang["col_model"]</label>
            <div class="col-sm-4 d-flex align-items-center">
                @Html.EditorFor(model => model.Model, new { htmlAttributes = new { @class = "form-control fixed-input" } })
                @Html.ValidationMessageFor(model => model.Model, "", new { @class = "text-danger inline-msg" })
            </div>
        </div>

        <!-- Year -->
        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">@Lang["col_year"]</label>
            <div class="col-sm-4 d-flex align-items-center">
                @Html.EditorFor(model => model.Year, new { htmlAttributes = new { @class = "form-control fixed-input" } })
                @Html.ValidationMessageFor(model => model.Year, "", new { @class = "text-danger inline-msg" })
            </div>
        </div>

        <!-- Engine Type -->
        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">@Lang["col_engine_type"]</label>
            <div class="col-sm-4 d-flex align-items-center">
                @Html.DropDownListFor(
                    model => model.EngineType,
                    new List<SelectListItem>
                    {
                        new SelectListItem { Text = Lang["select"].ToString(), Value = "" },
                        new SelectListItem { Text = "Diesel", Value = "Diesel" },
                        new SelectListItem { Text = "Electric", Value = "Electric" },
                        new SelectListItem { Text = "Gasoline", Value = "Gasoline" },
                        new SelectListItem { Text = "Hybrid", Value = "Hybrid" },
                        new SelectListItem { Text = "Turbo", Value = "Turbo" }
                    },
                    new { @class = "form-control fixed-input" })
                @Html.ValidationMessageFor(model => model.EngineType, "", new { @class = "text-danger inline-msg" })
            </div>
        </div>

        <!-- Mileage -->
        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">@Lang["col_mileage"]</label>
            <div class="col-sm-4 d-flex align-items-center">
                @Html.EditorFor(model => model.Mileage, new { htmlAttributes = new { @class = "form-control fixed-input" } })
                @Html.ValidationMessageFor(model => model.Mileage, "", new { @class = "text-danger inline-msg" })
            </div>
        </div>

        <!-- Buttons -->
        <div class="form-group" style="margin-top:20px;">
            <div class="col-md-offset-2 col-md-4 d-flex gap-3">
                <button type="submit" class="btn btn-primary">
                    @Lang["car_create_button"]
                </button>

                @Html.ActionLink(
                    Lang["car_create_back"].ToString(),
                    "Index",
                    null,
                    new { @class = "btn btn-secondary" }
                )
            </div>
        </div>

    </div>
}
