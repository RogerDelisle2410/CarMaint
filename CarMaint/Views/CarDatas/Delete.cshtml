@model CarMaint.Models.CarData

@{
    string lang = "en";
    if (Request.Cookies["lang"] != null)
    {
        lang = Request.Cookies["lang"].Value;
    }

    string jsonPath = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Lang", lang + ".json");
    string jsonText = System.IO.File.ReadAllText(jsonPath);
    var Lang = Newtonsoft.Json.Linq.JObject.Parse(jsonText);

    ViewBag.Title = Lang["car_delete_title"].ToString();
}

<h2>@Lang["car_delete_title"]</h2>
<h3>@Lang["car_delete_confirm"]</h3>

<div>
    <h4>@Lang["car_delete_info"]</h4>
    <hr />

    <dl class="dl-horizontal">

        <dt>@Lang["col_manufacturer"]</dt>
        <dd>@Html.DisplayFor(model => model.Manufacturer)</dd>

        <dt>@Lang["col_model"]</dt>
        <dd>@Html.DisplayFor(model => model.Model)</dd>

        <dt>@Lang["col_year"]</dt>
        <dd>@Html.DisplayFor(model => model.Year)</dd>

        <dt>@Lang["col_engine_type"]</dt>
        <dd>@Html.DisplayFor(model => model.EngineType)</dd>

        <dt>@Lang["col_mileage"]</dt>
        <dd>@Html.DisplayFor(model => model.Mileage)</dd>

        <dt>@Lang["col_customer_name"]</dt>
        <dd>@Html.DisplayFor(model => model.CustomerData.Name)</dd>

    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-actions no-color">
            <input type="submit" value="@Lang["car_delete_button"]" class="btn btn-default" />
            |
            @Html.ActionLink(Lang["car_delete_back"].ToString(), "Index")
        </div>
    }
</div>
