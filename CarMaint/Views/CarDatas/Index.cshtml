@model IEnumerable<CarMaint.Models.CarData>
@using Newtonsoft.Json.Linq

@{
    // Load language JSON (views cannot access layout variables)
    string lang = "en";
    if (Request.Cookies["lang"] != null)
    {
        lang = Request.Cookies["lang"].Value;
    }

    JObject Lang;

    try
    {
        string jsonPath = Server.MapPath("~/Lang/" + lang + ".json");
        string jsonText = System.IO.File.ReadAllText(jsonPath);
        Lang = JObject.Parse(jsonText);
    }
    catch
    {
        string fallbackPath = Server.MapPath("~/Lang/en.json");
        string fallbackText = System.IO.File.ReadAllText(fallbackPath);
        Lang = JObject.Parse(fallbackText);
    }
}

<h2>@Lang["veh_title"]</h2>

@using (Html.BeginForm())
{
    <p>
        @Lang["veh_find_brand"]: @Html.TextBox("SearchString")
        <input type="submit" value="@Lang["veh_search"]" />
    </p>
}

<p>
    @Html.ActionLink(
        Lang["veh_create_new"].ToString(),
        "Create",
        null,
        new { @class = "btn-menu" }
    )
</p>

<style>
    table {
        width: 100%;
        table-layout: fixed;
    }

    th, td {
        border: 1px solid black;
        padding: 6px;
    }

    .scrollingTable {
        max-height: 350px;
        overflow-y: auto;
        width: 100%;
        max-width: 1150px;
    }

    .btn-menu {
        display: inline-block;
        padding: 6px 12px;
        background: #f2f2f2;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-weight: bold;
        font-size: 12px;
        color: #333;
        text-decoration: none;
        transition: 0.15s ease-in-out;
    }

        .btn-menu:hover {
            background: #e6e6e6;
            border-color: #999;
            cursor: pointer;
        }
</style>

<script>
    function makeTableScroll() {
        var maxRows = 9;
        var table = document.getElementById('myTable');
        var wrapper = table.parentNode;
        var rowsInTable = table.rows.length;
        var height = 0;

        if (rowsInTable > maxRows) {
            for (var i = 0; i < maxRows; i++) {
                height += table.rows[i].clientHeight;
            }
            wrapper.style.height = height + "px";
        }
    }
</script>

<br />

<div class="scrollingTable">
    <table id="myTable" class="table">
        <thead>
            <tr>
                <th>@Lang["col_customer_name"]</th>
                <th>@Lang["col_manufacturer"]</th>
                <th>@Lang["col_model"]</th>
                <th>@Lang["col_year"]</th>
                <th>@Lang["col_engine"]</th>
                <th>@Lang["col_mileage"]</th>
                <th></th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.CustomerData.Name</td>
                    <td style="text-align:center;">@item.Manufacturer</td>
                    <td style="text-align:center;">@item.Model</td>
                    <td style="text-align:center;">@item.Year</td>
                    <td style="text-align:center;">@item.EngineType</td>
                    <td style="text-align:center;">@item.Mileage</td>

                    <td style="text-align:center; width:200px;">
                        @Html.ActionLink(
                            Lang["btn_edit"].ToString(),
                            "Edit",
                            new { id = item.CarId },
                            new { @class = "btn btn-primary btn-sm" }
                        )

                        @Html.ActionLink(
                            Lang["btn_details"].ToString(),
                            "Details",
                            new { id = item.CarId },
                            new { @class = "btn btn-info btn-sm", style = "margin-left: 6px;" }
                        )
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    makeTableScroll();
</script>
