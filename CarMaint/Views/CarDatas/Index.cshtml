                    <td style="text-align: center;">@Html.DisplayFor(modelItem => item.Year)</td>
                    <td style="text-align: center;">@Html.DisplayFor(modelItem => item.EngineType)</td>
                    <td style="text-align: center;">@Html.DisplayFor(modelItem => item.Mileage)</td>

                    <td style="text-align: center; width:200px;">
