@model IEnumerable<CarMaint.Models.CarData>

@{
    string lang = "en";
    if (Request.Cookies["lang"] != null)
    {
        lang = Request.Cookies["lang"].Value;
    }

    string jsonPath = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Lang", lang + ".json");
    string jsonText = System.IO.File.ReadAllText(jsonPath);
    var Lang = Newtonsoft.Json.Linq.JObject.Parse(jsonText);

    ViewBag.Title = Lang["veh_title"].ToString();
}

<h2>@Lang["veh_title"]</h2>

@using (Html.BeginForm())
{
    <p>
        @Lang["veh_find_brand"]: @Html.TextBox("SearchString")
        <input type="submit" value="@Lang["veh_search"]" />
    </p>
}

<p>
    @Html.ActionLink(Lang["veh_create_new"].ToString(), "Create")
</p>

<head>
    <style type="text/css">
        table {
            width: 90%;
            table-layout: fixed;
        }

        td {
            border: 1px solid black;
        }

        .scrollingTable {
            width: 1150px;
            overflow-y: auto;
        }
    </style>

    <script type="text/javascript">
        function makeTableScroll() {
            var maxRows = 10;
            var table = document.getElementById('myTable');
            var wrapper = table.parentNode;
            var rowsInTable = table.rows.length;
            var height = 0;
            if (rowsInTable > maxRows) {
                for (var i = 0; i < maxRows; i++) {
                    height += table.rows[i].clientHeight;
                }
                wrapper.style.height = height + "px";
            }
        }
    </script>
</head>

<body>
    <br />
    <table id="myTable2" class="table">
        <tr>
            <th>@Lang["col_customer_name"]</th>
            <th>@Lang["col_manufacturer"]</th>
            <th>@Lang["col_model"]</th>
            <th>@Lang["col_year"]</th>
            <th>@Lang["col_engine"]</th>
            <th>@Lang["col_mileage"]</th>
            <th></th>
        </tr>
    </table>
</body>

<body onload="makeTableScroll();">
    <div class="scrollingTable">
        <table id="myTable" class="table">
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.CustomerData.Name)</td>
                    <td style="text-align: center;">@Html.DisplayFor(modelItem => item.Manufacturer)</td>
                    <td style="text-align: center;">@Html.DisplayFor(modelItem => item.Model)</td>
                    <td style="text-align: center;">@Html.DisplayFor(modelItem => item.Year)</td>
                    <td style="text-align: center;">@Html.DisplayFor(modelItem => item.EngineType)</td>
                    <td style="text-align: center;">@Html.DisplayFor(modelItem => item.Mileage)</td>

                    <td style="text-align: center; width:200px;">
                        @Html.ActionLink(Lang["btn_edit"].ToString(), "Edit", new { id = item.CarId }) |
                        @Html.ActionLink(Lang["btn_details"].ToString(), "Details", new { id = item.CarId }) |
                        @Html.ActionLink(Lang["btn_delete"].ToString(), "Delete", new { id = item.CarId })
                    </td>
                </tr>
            }
        </table>
    </div>
</body>
