                        )

                        @Html.ActionLink(
                            Lang["btn_delete"].ToString(),
                            "Delete",
                            new { id = item.CarId },
                            new { @class = "btn btn-danger btn-sm", style = "margin-left: 6px;" }
                        )
                    </td>

