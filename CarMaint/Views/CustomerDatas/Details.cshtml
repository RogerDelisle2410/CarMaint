@model CarMaint.Models.CustomerData

@using Newtonsoft.Json.Linq

@{
    string lang = "en";
    if (Request.Cookies["lang"] != null)
    {
        lang = Request.Cookies["lang"].Value;
    }

    JObject Lang;

    try
    {
        string jsonPath = Server.MapPath("~/Lang/" + lang + ".json");
        string jsonText = System.IO.File.ReadAllText(jsonPath);
        Lang = JObject.Parse(jsonText);
    }
    catch
    {
        // Fallback to English if Azure can't find the file
        string fallbackPath = Server.MapPath("~/Lang/en.json");
        string fallbackText = System.IO.File.ReadAllText(fallbackPath);
        Lang = JObject.Parse(fallbackText);
    }
}


<h2>@Lang["details_title"]</h2>

<div>
    <h4>@Lang["details_customer_info"]</h4>
    <hr />

    <dl class="dl-horizontal">

        <dt>@Lang["col_name"]</dt>
        <dd>@Html.DisplayFor(model => model.Name)</dd>

        <dt>@Lang["col_address"]</dt>
        <dd>@Html.DisplayFor(model => model.Address)</dd>

        <dt>@Lang["col_city"]</dt>
        <dd>@Html.DisplayFor(model => model.City)</dd>

        <dt>@Lang["col_postal"]</dt>
        <dd>@Html.DisplayFor(model => model.PostalCode)</dd>

        <dt>@Lang["col_phone"]</dt>
        <dd>@Html.DisplayFor(model => model.Phone)</dd>

    </dl>
</div>
<div class="d-flex gap-3">
    @Html.ActionLink(
        Lang["details_edit"].ToString(),
        "Edit",
        new { id = Model.CustomerId },
        new { @class = "btn btn-primary" }
    )

    @Html.ActionLink(
        Lang["details_back_to_list"].ToString(),
        "Index",
        null,
        new { @class = "btn btn-secondary" }
    )
</div> 
