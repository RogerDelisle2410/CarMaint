@model CarMaint.Models.CustomerData

@using Newtonsoft.Json.Linq

@{
    string lang = "en";
    if (Request.Cookies["lang"] != null)
    {
        lang = Request.Cookies["lang"].Value;
    }

    JObject Lang;

    try
    {
        string jsonPath = Server.MapPath("~/Lang/" + lang + ".json");
        string jsonText = System.IO.File.ReadAllText(jsonPath);
        Lang = JObject.Parse(jsonText);
    }
    catch
    {
        string fallbackPath = Server.MapPath("~/Lang/en.json");
        string fallbackText = System.IO.File.ReadAllText(fallbackPath);
        Lang = JObject.Parse(fallbackText);
    }
}

<h2>@Lang["edit_title"]</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <h4>@Lang["edit_customer_info"]</h4>
        <hr />

        @Html.ValidationSummary(true, "", new { @class = "text-danger inline-msg" })
        @Html.HiddenFor(model => model.CustomerId)

        <!-- Name -->
        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">@Lang["col_name"]</label>
            <div class="col-sm-4 d-flex align-items-center">
                @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control fixed-input" } })
                @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger inline-msg" })
            </div>
        </div>

        <!-- Address -->
        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">@Lang["col_address"]</label>
            <div class="col-sm-4 d-flex align-items-center">
                @Html.EditorFor(model => model.Address, new { htmlAttributes = new { @class = "form-control fixed-input" } })
                @Html.ValidationMessageFor(model => model.Address, "", new { @class = "text-danger inline-msg" })
            </div>
        </div>

        <!-- City -->
        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">@Lang["col_city"]</label>
            <div class="col-sm-4 d-flex align-items-center">
                @Html.EditorFor(model => model.City, new { htmlAttributes = new { @class = "form-control fixed-input" } })
                @Html.ValidationMessageFor(model => model.City, "", new { @class = "text-danger inline-msg" })
            </div>
        </div>

        <!-- Postal Code -->
        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">@Lang["col_postal"]</label>
            <div class="col-sm-4 d-flex align-items-center">
                @Html.EditorFor(model => model.PostalCode, new { htmlAttributes = new { @class = "form-control fixed-input" } })
                @Html.ValidationMessageFor(model => model.PostalCode, "", new { @class = "text-danger inline-msg" })
            </div>
        </div>

        <!-- Phone -->
        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">@Lang["col_phone"]</label>
            <div class="col-sm-4 d-flex align-items-center">
                @Html.EditorFor(model => model.Phone, new { htmlAttributes = new { @class = "form-control fixed-input" } })
                @Html.ValidationMessageFor(model => model.Phone, "", new { @class = "text-danger inline-msg" })
            </div>
        </div>

        <!-- Buttons -->
        <div class="form-group" style="margin-top:20px;">
            <div class="col-md-offset-2 col-md-4 d-flex gap-3">
                <button type="submit" class="btn btn-primary">
                    @Lang["edit_save"]
                </button>

                @Html.ActionLink(
                    Lang["edit_back_to_list"].ToString(),
                    "Index",
                    null,
                    new { @class = "btn btn-secondary" }
                )
            </div>
        </div>

    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
