@using Newtonsoft.Json.Linq

@{
    ViewBag.Title = "Home Page";
}

@{
    string lang = "en";
    if (Request.Cookies["lang"] != null)
    {
        lang = Request.Cookies["lang"].Value;
    }

    JObject Lang;
    

    try
    {
        string jsonPath = Server.MapPath("~/Lang/" + lang + ".json");
        string jsonText = System.IO.File.ReadAllText(jsonPath);
        Lang = JObject.Parse(jsonText);
    }
    catch
    {
        string fallbackPath = Server.MapPath("~/Lang/en.json");
        string fallbackText = System.IO.File.ReadAllText(fallbackPath);
        Lang = JObject.Parse(fallbackText);
    }

    // Choose image based on language
    string imagePath = "~/Image/Crappy_Tire_en.png";

    if (lang == "fr")
    {
        imagePath = "~/Image/Crappy_Tire_fr.png";
    }
    else if (lang == "es")
    {
        imagePath = "~/Image/Crappy_Tire_es.png";
    }
}

<div class="home-fullscreen">

    <div style="display:flex; height:100%; overflow:hidden; align-items:flex-start;">

        <div style="width:25%; background:white; padding:30px; font-weight:bold; font-size:14px; line-height:1.8;
                    box-shadow:0 0 15px rgba(0,0,0,0.15); border-radius:10px; margin-left:20px; margin-top:20px;">

            @Html.ActionLink(Lang["menu_new_ticket"].ToString(), "Index", "MaintTicket", null, new { @class = "menu-button" })
            @Html.ActionLink(Lang["menu_customer_info"].ToString(), "Index", "CustomerDatas", null, new { @class = "menu-button" })
            @Html.ActionLink(Lang["menu_car_info"].ToString(), "Index", "CarDatas", null, new { @class = "menu-button" })
            @Html.ActionLink(Lang["menu_maint_type"].ToString(), "Index", "MaintenanceTypes", null, new { @class = "menu-button" })
            @Html.ActionLink(Lang["menu_maint_history"].ToString(), "Index", "MaintenanceHistories", null, new { @class = "menu-button" })

        </div>

        <div style="width:75%; display:flex; justify-content:center; align-items:flex-start; padding-left:40px; padding-top:20px;">
            <img src="@Url.Content(imagePath)" alt="Crappy Tire" style="max-width:90%; height:80%;" />
        </div>

    </div>


     
    <!-- ONLY ONE HELP BUTTON -->
    <button id="helpBtn" style="margin-left:20px;">?</button>

    <!-- ONLY ONE POPUP -->
    <div id="helpPopup" class="hidden"
         style="position:fixed; top:20%; left:20%; background:white; border:2px solid #333; padding:20px; z-index:9999;">

        <p style="font-size:14px;">@Lang["help_title"]</p>
        <p>@Lang["help_text"]</p>
        <button onclick="document.getElementById('helpPopup').classList.add('hidden')">Close</button>
    </div>
</div>

<style>
    .hidden {
        display: none;
    }

    .menu-button {
        display: block;
        width: 100%;
        padding: 12px 18px;
        margin-bottom: 15px;
        background: #f2f2f2;
        border: 1px solid #ccc;
        border-radius: 6px;
        font-weight: bold;
        font-size: 14px;
        text-align: left;
        color: #333;
        text-decoration: none;
        transition: 0.15s ease-in-out;
    }

        .menu-button:hover {
            background: #e6e6e6;
            border-color: #999;
            cursor: pointer;
        }
</style>
<script>
    function showHelp() {
        document.getElementById("helpPopup").classList.remove("hidden");
    }
    document.addEventListener("DOMContentLoaded", function () {
        document.getElementById("helpBtn").addEventListener("click", showHelp);
    });
</script>

