@model IEnumerable<CarMaint.Models.MaintenanceType>

@using System.IO
@using Newtonsoft.Json.Linq

@{
    string lang = "en";

    var cookie = Request.Cookies["lang"];
    if (cookie != null && !string.IsNullOrEmpty(cookie.Value))
    {
        lang = cookie.Value;
    }

    string jsonPath = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Lang", lang + ".json");
    string jsonText = File.ReadAllText(jsonPath);
    JObject Lang = JObject.Parse(jsonText);

    ViewBag.Title = Lang["ticket_title"].ToString();
}
<div id="customAlert"
     style="display:none;
            position:fixed;
            top:50%;
            left:50%;
            transform:translate(-50%, -50%);
            background:white;
            border:3px solid #007bff;
            padding:20px;
            border-radius:8px;
            box-shadow:0 0 15px rgba(0,0,0,0.3);
            z-index:9999;
            text-align:center;
            width:300px;">
</div>

<h2>@Lang["ticket_title"]</h2>
<h4>@Lang["ticket_select_type_required"]</h4>

<style>
    td {
        border: 1px solid black;
    }

    .scrollingTable {
        width: 50%;
        overflow-y: auto;
    }

    tr.noBorder td {
        border: 1px solid red;
    }
</style>

@*<script src="//code.jquery.com/jquery-3.1.0.slim.min.js"></script>*@
<script src="sumTable.js"></script>
@*<script src="https://ajax.googleapis.com/ajax/libs/jquery/2.1.1/jquery.min.js"></script>*@
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

<script>
    var orderArray = [];
    var sumTotal = 0;

    $(document).ready(function () {
        $('input:checkbox').prop('checked', false);
        $("#HeaderTable").hide();
        $("#MainTable").hide();
        $("#SummaryBar").hide();
    });

    function makeTableScroll() {
        var maxRows = 9;
        var table = document.getElementById('myTable5');
        var wrapper = table.parentNode;
        var rowsInTable = table.rows.length;
        var height = 0;

        if (rowsInTable > maxRows) {
            for (var i = 0; i < maxRows; i++) {
                height += table.rows[i].clientHeight;
            }
            wrapper.style.height = height + "px";
        }
    }

    function getRow(n) {
        var row = n.parentNode.parentNode;
        var cols = row.getElementsByTagName("td");

        var maintid = parseInt(cols[0].innerText);
        var idx = $.inArray(maintid, orderArray);

        if (idx === -1) {
            orderArray.push(maintid);
            $("#HeaderTable").show();
            $("#MainTable").show();
            $("#SummaryBar").show();

            var table = document.getElementById("MainTable");
            var newRow = table.insertRow(0);

            var cell1 = newRow.insertCell(0); // maint id
            var cell2 = newRow.insertCell(1); // type
            var cell3 = newRow.insertCell(2); // cost

            cell1.innerHTML = maintid;
            cell2.innerHTML = cols[1].innerText;
            cell3.innerHTML = parseFloat(cols[2].innerText).toFixed(2);

            cell3.style.width = "80px";
            cell3.style.textAlign = "right";
            cell3.style.whiteSpace = "nowrap";

            var sum = 0;
            var cells = document.querySelectorAll("#MainTable tr td:last-child");
            cells.forEach(function (c) {
                sum += parseFloat(c.innerText);
            });
            $("#TableFooter").show();
            $("#aTotal").text(sum.toFixed(2));

        }
        else {
            orderArray.splice(idx, 1);

            var table = document.getElementById("MainTable");
            var cells = table.getElementsByTagName("td");

            for (var x = 0; x < cells.length; x++) {
                if (cells[x].innerText == maintid) {
                    var r = cells[x].parentNode;
                    r.parentNode.removeChild(r);
                    break;
                }
            }

            var sum = 0;
            var cells2 = document.querySelectorAll("#MainTable tr td:last-child");

            cells2.forEach(function (c) {
                sum += parseFloat(c.innerText);
            });

            $("#aTotal").text(sum.toFixed(2));

            if (orderArray.length === 0) {
                $("#HeaderTable").hide();
                $("#MainTable").hide();
                $("#TableFooter").hide();
                $("#theButton").hide();
            }
        }
    }

    function proceed() {
        if (orderArray.length > 0) {
            $.ajax({
                type: "POST",
                traditional: true,
                url: "AddToHistory",
                async: false,
                data: { 'arrayOfValues': orderArray },
                dataType: "json",

                success: function (json) {
                showAlert("@Lang["msg_history_updated"]");

                if (json.isRedirect) {
                    window.location.href = json.redirectUrl;
                    }
                },
                error: function () {
                    showAlert("@Lang["msg_ajax_error"]" + " " + orderArray);
                }
            });

            $('input:checkbox').prop('checked', false);
        }
    }

    function showAlert(message) {
        var box = document.getElementById("customAlert");
        box.innerText = message;
        box.style.display = "block";

        setTimeout(function () {
            box.style.display = "none";
        }, 2500);
    }

</script>

<table id="myTable1" class="table col-lg-12">
    <tr>
        <th class="col-lg-2">@Lang["col_customer"]</th>
        <th class="col-lg-2">@Lang["col_manufacturer"]</th>
        <th class="col-lg-2">@Lang["col_model"]</th>
        <th class="col-lg-2">@Lang["col_engine_type"]</th>
        <th class="col-lg-1">@Lang["col_year"]</th>
        <th class="col-lg-3" style="border:none"></th>
    </tr>

    <tr style="background-color:white">
        <td>@Session["CustomerName"]</td>
        <td>@Session["Manufacturer"]</td>
        <td>@Session["Model"]</td>
        <td>@Session["EngineType"]</td>
        <td>@Session["Year"]</td>
        <th style="border:none"></th>
    </tr>
</table>

<div class="row" onload="makeTableScroll();">
    <div class="table-responsive col-md-6">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th class="col-lg-1" style="border:none">@Lang["col_maint_id"]</th>
                    <th class="col-lg-3" style="border:none">@Lang["col_task_name"]</th>
                    <th class="col-lg-1" style="border:none">@Lang["col_cost"]</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="col-lg-1" style="text-align:center; vertical-align:middle;">
                            @item.MaintId
                        </td>

                        <td class="col-lg-3">
                            @item.TaskName   <!-- TRANSLATED VALUE -->
                        </td>

                        <td class="col-lg-1" style="text-align:right; vertical-align:middle;">
                            @string.Format("{0:0.00}", Convert.ToDecimal(item.Cost))
                        </td>

                        <td class="col-lg-1" style="text-align:center; vertical-align:middle;">
                            <input type="checkbox" name="test" value="1" onclick="getRow(this)" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="table-responsive col-md-6">

        <!-- ⭐ SUMMARY TABLE ⭐ -->
        <table id="HeaderTable" class="table table-striped">
            <thead>
                <tr>
                    <th class="col-lg-1" style="border:none">@Lang["col_maint_id"]</th>
                    <th class="col-lg-2" style="border:none">@Lang["col_type"]</th>
                    <th class="col-lg-1" style="border:none">@Lang["col_cost"]</th>

                </tr>
            </thead>

            <tbody id="MainTable"></tbody>
        </table>

        <div id="SummaryBar" style="display:none; margin-bottom:10px;">

            <div style="display:flex; justify-content:space-between; align-items:center; padding:6px 0;">

                <!-- Button -->
                <button id="theButton"
                        onclick="proceed()"
                        class="btn btn-primary btn-sm"
                        style="padding:6px 14px;">
                    @Lang["btn_create_ticket"]
                </button>

                <!-- Total -->
                <div style="font-size:18px; font-weight:bold;">
                    @Lang["col_total"] $ <span id="aTotal"> 0.00</span>
                </div>
            </div>

            <hr style="margin:8px 0;" />
        </div>
    </div>
</div>
