@model IEnumerable<CarMaint.Models.MaintenanceType>

@using System.IO
@using Newtonsoft.Json.Linq

@{
    string lang = "en";

    var cookie = Request.Cookies["lang"];
    if (cookie != null && !string.IsNullOrEmpty(cookie.Value))
    {
        lang = cookie.Value;
    }

    string jsonPath = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Lang", lang + ".json");
    string jsonText = File.ReadAllText(jsonPath);
    JObject Lang = JObject.Parse(jsonText);

    ViewBag.Title = Lang["ticket_title"].ToString();
}
<div id="customAlert"
     style="display:none;
            position:fixed;
            top:50%;
            left:50%;
            transform:translate(-50%, -50%);
            background:white;
            border:3px solid #007bff;
            padding:20px;
            border-radius:8px;
            box-shadow:0 0 15px rgba(0,0,0,0.3);
            z-index:9999;
            text-align:center;
            width:300px;">
</div>

<h2>@Lang["ticket_title"]</h2>
<h4>@Lang["ticket_select_type_required"]</h4>

<style>
    td {
        border: 1px solid black;
    }

    .scrollingTable {
        width: 50%;
        overflow-y: auto;
    }

    tr.noBorder td {
        border: 1px solid red;
    }
</style>

@*<script src="//code.jquery.com/jquery-3.1.0.slim.min.js"></script>*@
<script src="sumTable.js"></script>
@*<script src="https://ajax.googleapis.com/ajax/libs/jquery/2.1.1/jquery.min.js"></script>*@
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

<script>
    var orderArray = [];
    var sumTotal = 0;

    $(document).ready(function () {
        $('input:checkbox').prop('checked', false);
        $("#HeaderTable").hide();
        $("#MainTable").hide();
        $("#SummaryBar").hide();
    });

    function makeTableScroll() {
        var maxRows = 9;
        var table = document.getElementById('myTable5');
        var wrapper = table.parentNode;
        var rowsInTable = table.rows.length;
        var height = 0;

        if (rowsInTable > maxRows) {
            for (var i = 0; i < maxRows; i++) {
                height += table.rows[i].clientHeight;
            }
            wrapper.style.height = height + "px";
        }
    }
    function getRow(cb) {

        // Get the clicked row
        const row = cb.closest("tr");

        // Extract values from the hidden + visible cells
        const maintid = parseInt(row.querySelector(".maint-id").textContent.trim());
        const type = row.children[1].textContent.trim();
        const cost = parseFloat(row.children[2].textContent.trim()).toFixed(2);

        // Check if already selected
        const idx = orderArray.indexOf(maintid);

        // ============================
        // ADD ROW
        // ============================
        if (idx === -1) {

            orderArray.push(maintid);

            // Show summary UI
            $("#HeaderTable").show();
            $("#MainTable").show();
            $("#SummaryBar").show();

            // Create new summary row
            const newRow = document.createElement("tr");

            newRow.innerHTML = `
            <td style="display:none;">
                <span class="maint-id">${maintid}</span>
            </td>

            <td>${type}</td>

            <td style="text-align:right; white-space:nowrap;">
                ${cost}
            </td>
        `;

            document.getElementById("MainTable").prepend(newRow);

            updateTotal();
        }

        // ============================
        // REMOVE ROW
        // ============================
        else {

            orderArray.splice(idx, 1);

            const table = document.getElementById("MainTable");
            const rows = table.querySelectorAll("tr");

            rows.forEach(r => {
                const idCell = r.querySelector(".maint-id");
                if (idCell && parseInt(idCell.textContent) === maintid) {
                    r.remove();
                }
            });

            updateTotal();

            if (orderArray.length === 0) {
                $("#HeaderTable").hide();
                $("#MainTable").hide();
                $("#SummaryBar").hide();
            }
        }
    } 

    // =====================================
    // TOTAL CALCULATION (clean + bulletproof)
    // =====================================
    function updateTotal() {

        let sum = 0;

        const costCells = document.querySelectorAll("#MainTable tr td:last-child");

        costCells.forEach(c => {
            const val = parseFloat(c.textContent);
            if (!isNaN(val)) sum += val;
        });

        $("#aTotal").text(sum.toFixed(2));
    } 

    function proceed() {
        if (orderArray.length > 0) {
            $.ajax({
                type: "POST",
                traditional: true,
                url: "AddToHistory",
                async: false,
                data: { 'arrayOfValues': orderArray },
                dataType: "json",

                success: function (json) {
                showAlert("@Lang["msg_history_updated"]");

                if (json.isRedirect) {
                    window.location.href = json.redirectUrl;
                    }
                },
                error: function () {
                    showAlert("@Lang["msg_ajax_error"]" + " " + orderArray);
                }
            });

            $('input:checkbox').prop('checked', false);
        }
    }

    function showAlert(message) {
        var box = document.getElementById("customAlert");
        box.innerText = message;
        box.style.display = "block";

        setTimeout(function () {
            box.style.display = "none";
        }, 2500);
    }

</script>

<table id="myTable1" class="table col-lg-12">
    <tr>
        <th class="col-lg-2">@Lang["col_customer"]</th>
        <th class="col-lg-2">@Lang["col_manufacturer"]</th>
        <th class="col-lg-2">@Lang["col_model"]</th>
        <th class="col-lg-2">@Lang["col_engine_type"]</th>
        <th class="col-lg-1">@Lang["col_year"]</th>
        <th class="col-lg-3" style="border:none"></th>
    </tr>

    <tr style="background-color:white">
        <td>@Session["CustomerName"]</td>
        <td>@Session["Manufacturer"]</td>
        <td>@Session["Model"]</td>
        <td>@Session["EngineType"]</td>
        <td>@Session["Year"]</td>
        <th style="border:none"></th>
    </tr>
</table>

<div class="row" onload="makeTableScroll();">

    <!-- ========================= -->
    <!-- LEFT TABLE (MAIN LIST)   -->
    <!-- ========================= -->
    <div class="table-responsive col-md-6">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th class="col-lg-1" style="border:none; display:none;">
                        @Lang["col_maint_id"]
                    </th>
                    <th class="col-lg-3" style="border:none;">
                        @Lang["col_task_name"]
                    </th>
                    <th class="col-lg-1" style="border:none;">
                        @Lang["col_cost"]
                    </th>
                    <th class="col-lg-1" style="border:none;"></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="col-lg-1" style="display:none;">
                            <span class="maint-id">@item.MaintId</span>
                        </td>

                        <td class="col-lg-3">@item.TaskName</td>

                        <td class="col-lg-1" style="text-align:right;">
                            @string.Format("{0:0.00}", Convert.ToDecimal(item.Cost))
                        </td>

                        <td class="col-lg-1" style="text-align:center;">
                            <input type="checkbox" onclick="getRow(this)" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>



    <!-- ========================= -->
    <!-- RIGHT TABLE (SUMMARY)     -->
    <!-- ========================= -->
    <div class="table-responsive col-md-6">

        <table id="HeaderTable" class="table table-striped">
            <thead>
                <tr>
                    <th class="col-lg-1" style="border:none; display:none;">
                        @Lang["col_maint_id"]
                    </th>
                    <th class="col-lg-2" style="border:none;">
                        @Lang["col_type"]
                    </th>
                    <th class="col-lg-1" style="border:none;">
                        @Lang["col_cost"]
                    </th>
                </tr>
            </thead>

            <tbody id="MainTable"></tbody>
        </table>




        <!-- ========================= -->
        <!-- SUMMARY BAR               -->
        <!-- ========================= -->
        <div id="SummaryBar" style="display:none; margin-bottom:10px;">

            <div style="display:flex; justify-content:space-between; align-items:center; padding:6px 0;">

                <!-- Button -->
                <button id="theButton"
                        onclick="proceed()"
                        class="btn btn-primary btn-sm"
                        style="padding:6px 14px;">
                    @Lang["btn_create_ticket"]
                </button>

                <!-- Total -->
                <div style="font-size:18px; font-weight:bold;">
                    @Lang["col_total"] $ <span id="aTotal">0.00</span>
                </div>
            </div>

            <hr style="margin:8px 0;" />
        </div>

    </div>
</div>
