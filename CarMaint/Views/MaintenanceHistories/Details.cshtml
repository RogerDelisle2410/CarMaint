@model CarMaint.Models.MaintenanceHistory
@using System.IO;

@{
    string lang = "en";
    if (Request.Cookies["lang"] != null)
    {
        lang = Request.Cookies["lang"].Value;
    }

    string jsonPath = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Lang", lang + ".json");
    string jsonText = System.IO.File.ReadAllText(jsonPath);
    var Lang = Newtonsoft.Json.Linq.JObject.Parse(jsonText);

    ViewBag.Title = Lang["details_title"].ToString();
}

<h2>@Lang["details_title"]</h2>

<div>
    <h4>@Lang["maintenance_history"]</h4>
    <hr />
    <dl class="dl-horizontal">

        <dt>@Lang["date"]</dt>
        <dd>@Html.DisplayFor(model => model.Date)</dd>

        <dt>@Lang["cost"]</dt>
        <dd>@Html.DisplayFor(model => model.Cost)</dd>

        <dt>@Lang["task_name"]</dt>
        <dd>@Html.DisplayFor(model => model.MaintenanceType.TaskName)</dd>

        <dt>@Lang["customer_name"]</dt>
        <dd>@Html.DisplayFor(model => model.CustomerData.Name)</dd>

        <dt>@Lang["car_manufacturer"]</dt>
        <dd>@Html.DisplayFor(model => model.CarData.Manufacturer)</dd>

    </dl>
</div>

<p>
    @Html.ActionLink(Lang["edit"].ToString(), "Edit", new { id = Model.HistoryId }) |
    @Html.ActionLink(Lang["back_to_list"].ToString(), "Index")
</p>
