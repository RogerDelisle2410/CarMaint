@model CarMaint.Models.MaintenanceHistory
@using System.IO
@using Newtonsoft.Json.Linq

@{
    string lang = "en";
    if (Request.Cookies["lang"] != null)
    {
        lang = Request.Cookies["lang"].Value;
    }

    JObject Lang;

    try
    {
        string jsonPath = Server.MapPath("~/Lang/" + lang + ".json");
        string jsonText = System.IO.File.ReadAllText(jsonPath);
        Lang = JObject.Parse(jsonText);
    }
    catch
    {
        string fallbackPath = Server.MapPath("~/Lang/en.json");
        string fallbackText = System.IO.File.ReadAllText(fallbackPath);
        Lang = JObject.Parse(fallbackText);
    }
}

<h2>@Lang["edit_title"]</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <h4>@Lang["maintenance_history"]</h4>
    <hr />

    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(model => model.HistoryId)

    <!-- Car ID -->
    <div class="row mb-3">
        <label class="col-sm-2 col-form-label">@Lang["car_id"]</label>
        <div class="col-sm-4">
            @Html.DropDownList("CarId", null, new { @class = "form-control" })
            @Html.ValidationMessageFor(model => model.CarId, "", new { @class = "text-danger" })
        </div>
    </div>

    <!-- Task Name -->
    <div class="row mb-3">
        <label class="col-sm-2 col-form-label">@Lang["task_name"]</label>
        <div class="col-sm-4">
            @Html.DropDownList("MaintId", null, new { @class = "form-control" })
            @Html.ValidationMessageFor(model => model.MaintId, "", new { @class = "text-danger" })
        </div>
    </div>

    <!-- Date -->
    <div class="row mb-3">
        <label class="col-sm-2 col-form-label">@Lang["date"]</label>
        <div class="col-sm-4">
            @Html.EditorFor(model => model.Date, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Date, "", new { @class = "text-danger" })
        </div>
    </div>

    <!-- Customer ID -->
    <div class="row mb-3">
        <label class="col-sm-2 col-form-label">@Lang["cust_id"]</label>
        <div class="col-sm-4">
            @Html.DropDownList("CustId", null, new { @class = "form-control" })
            @Html.ValidationMessageFor(model => model.CustId, "", new { @class = "text-danger" })
        </div>
    </div>

    <!-- Cost -->
    <div class="row mb-3">
        <label class="col-sm-2 col-form-label">@Lang["cost"]</label>
        <div class="col-sm-4">
            @Html.EditorFor(model => model.Cost, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Cost, "", new { @class = "text-danger" })
        </div>
    </div>

    <!-- Buttons -->
    <div class="row mt-4">
        <div class="col-sm-6" style="display:flex; gap:12px;">
            <button type="submit" class="btn btn-primary">@Lang["save"]</button>
            @Html.ActionLink(Lang["back_to_list"].ToString(), "Index", null, new { @class = "btn btn-secondary" })
        </div>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
