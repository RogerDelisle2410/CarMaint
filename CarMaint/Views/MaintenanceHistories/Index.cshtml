@model IEnumerable<CarMaint.Models.MaintenanceHistory>
@using Newtonsoft.Json.Linq

@{
    string lang = "en";
    if (Request.Cookies["lang"] != null)
    {
        lang = Request.Cookies["lang"].Value;
    }
    JObject Lang;

    try
    {
        string jsonPath = Server.MapPath("~/Lang/" + lang + ".json");
        Lang = JObject.Parse(System.IO.File.ReadAllText(jsonPath));
    }
    catch
    {
        string fallbackPath = Server.MapPath("~/Lang/en.json");
        Lang = JObject.Parse(System.IO.File.ReadAllText(fallbackPath));
    }
}

<h2 class="mb-4">@Lang["hist_title"]</h2>

@using (Html.BeginForm())
{
    <div class="mb-3 d-flex align-items-center gap-3">
        <label class="fw-bold">@Lang["hist_find_by_name"]:</label>
        @Html.TextBox("SearchString", null, new { @class = "form-control fixed-input" })
        <input type="submit" value="@Lang["hist_search"]" class="btn btn-primary" />
    </div>
}

<style>
    .mh-table-header th {
        text-align: center;
        font-weight: bold;
        padding: 8px;
        background-color: #f7f7f7;
        border-bottom: 2px solid #ccc;
    }

    .mh-table td {
        padding: 8px;
        border-bottom: 1px solid #ddd;
    }

    .mh-scroll {
        max-height: 420px;
        overflow-y: auto;
        border: 1px solid #ccc;
        border-radius: 6px;
        background: white;
    }

    .mh-total-row {
        background-color: #fafafa;
        font-weight: bold;
    }

        .mh-total-row td {
            padding: 8px;
            border-top: 2px solid #ccc;
        }

    .mh-actions a {
        margin-right: 6px;
    }
</style>

<div class="table-responsive" style="width:65%; margin:0 auto;">

    <table class="table " style="margin:0; table-layout:fixed; width:100%;">

        <!-- FIXED HEADER -->
        <thead class="mh-table-header" style="display:table; width:100%; table-layout:fixed;">
            <tr style="display:table; width:100%; table-layout:fixed;">
                <th style="width:20%;">@Lang["col_hist_customer"]</th>
                <th style="width:20%;">@Lang["col_hist_manufacturer"]</th>
                <th style="width:20%;">@Lang["col_hist_task"]</th>
                <th style="width:20%;">@Lang["col_hist_date"]</th>
                <th style="width:20%;">@Lang["col_hist_cost"]</th>
            </tr>
        </thead>

        <!-- SCROLLABLE BODY -->
        <tbody class="mh-scroll" style="display:block; max-height:420px; overflow-y:auto; width:100%;">
            @foreach (var group in Model.GroupBy(p => p.CustId))
            {
                foreach (var item in group)
                {
                    <tr style="display:table; width:100%; table-layout:fixed;">
                        <td style="width:20%;">@item.CustomerData.Name</td>
                        <td style="width:20%;" class="text-center">@item.CarData.Manufacturer</td>
                        <td style="width:20%;" class="text-center">
                            @{
                                string taskName = item.MaintenanceType.TaskName_EN;

                                if (lang == "fr")
                                {
                                    taskName = item.MaintenanceType.TaskName_FR;
                                }
                                else if (lang == "es")
                                {
                                    taskName = item.MaintenanceType.TaskName_ES;
                                }
                            }
                            @taskName
                        </td>

                        <td style="width:20%;" class="text-end">@item.Date.ToShortDateString()</td>
                        <td style="width:20%;" class="text-end">@string.Format("{0:c}", item.Cost)</td>
                    </tr>
                }

                <!-- GROUP TOTAL -->
                <tr class="mh-total-row" style="display:table; width:100%; table-layout:fixed;">
                    <td colspan="4" style="width:80%;"></td>
                    <td style="width:20%;" class="text-end">
                        @Lang["hist_total_cost"]: @string.Format("{0:c}", group.Sum(x => x.Cost))
                    </td>
                </tr>
            }
        </tbody>

    </table>
</div>


