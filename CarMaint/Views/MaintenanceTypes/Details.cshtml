@model CarMaint.Models.MaintenanceType
@using System.IO;

@using Newtonsoft.Json.Linq

@{
    string lang = "en";
    if (Request.Cookies["lang"] != null)
    {
        lang = Request.Cookies["lang"].Value;
    }

    JObject Lang;

    try
    {
        string jsonPath = Server.MapPath("~/Lang/" + lang + ".json");
        string jsonText = System.IO.File.ReadAllText(jsonPath);
        Lang = JObject.Parse(jsonText);
    }
    catch
    {
        // Fallback to English if Azure can't find the file
        string fallbackPath = Server.MapPath("~/Lang/en.json");
        string fallbackText = System.IO.File.ReadAllText(fallbackPath);
        Lang = JObject.Parse(fallbackText);
    }
}



<h2>@Lang["details_title"]</h2>

<div>
    <h4>@Lang["type_of_maintenance"]</h4>
    <hr />
    <dl class="dl-horizontal">

        <dt>@Lang["task_name"]</dt>
        <dd>@Html.DisplayFor(model => model.TaskName)</dd>

        <dt>@Lang["cost"]</dt>
        <dd>@Html.DisplayFor(model => model.Cost)</dd>

        <dt>@Lang["gas"]</dt>
        <dd>@Html.DisplayFor(model => model.Gas)</dd>

        <dt>@Lang["diesel"]</dt>
        <dd>@Html.DisplayFor(model => model.Diesel)</dd>

        <dt>@Lang["electric"]</dt>
        <dd>@Html.DisplayFor(model => model.Electric)</dd>

        <dt>@Lang["hybrid"]</dt>
        <dd>@Html.DisplayFor(model => model.Hybrid)</dd>

        <dt>@Lang["turbo"]</dt>
        <dd>@Html.DisplayFor(model => model.Turbo)</dd>
    </dl>
</div>
<div style="display:flex; gap:12px;">

    @Html.ActionLink(
        Lang["edit"].ToString(),
        "Edit",
        new { id = Model.MaintId },
        new { @class = "btn btn-primary" }
    )

    @Html.ActionLink(
        Lang["back_to_list"].ToString(),
        "Index",
        null,
        new { @class = "btn btn-secondary" }
    )

</div> 