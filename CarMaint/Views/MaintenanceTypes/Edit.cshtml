@model CarMaint.Models.MaintenanceType
@using System.IO;
@using Newtonsoft.Json.Linq

@{
    // Load selected language
    string lang = "en";
    if (Request.Cookies["lang"] != null)
    {
        lang = Request.Cookies["lang"].Value;
    }

    JObject LangEN = JObject.Parse(System.IO.File.ReadAllText(Server.MapPath("~/Lang/en.json")));
    JObject LangFR = JObject.Parse(System.IO.File.ReadAllText(Server.MapPath("~/Lang/fr.json")));
    JObject LangES = JObject.Parse(System.IO.File.ReadAllText(Server.MapPath("~/Lang/es.json")));

    // Active language
    JObject Lang = lang == "fr" ? LangFR : lang == "es" ? LangES : LangEN;
}

<h2>@Lang["edit_title"]</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <h4>@Lang["type_of_maintenance"]</h4>
        <hr />

        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        @Html.HiddenFor(model => model.MaintId)

        <div class="form-group">
            <label class="control-label col-md-2">@Lang["task_name"]</label>
            <div class="col-md-10">

                @if (lang == "en")
                {
                    <label><strong>@Lang["english_name"]</strong></label>
                    @Html.TextBoxFor(model => model.TaskName_EN, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.TaskName_EN, null, new { @class = "text-danger" })
                }
                else if (lang == "fr")
                {
                    <label><strong>@Lang["french_name"]</strong></label>
                    @Html.TextBoxFor(model => model.TaskName_FR, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.TaskName_FR, null, new { @class = "text-danger" })
                }
                else if (lang == "es")
                {
                    <label><strong>@Lang["spanish_name"]</strong></label>
                    @Html.TextBoxFor(model => model.TaskName_ES, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.TaskName_ES, null, new { @class = "text-danger" })
                }

            </div>
        </div>

        <div class="form-group">
            @Html.Label(Lang["cost"].ToString(), new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.Cost, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.Cost, null, new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.Label(Lang["gas"].ToString(), new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                <div class="checkbox">
                    @Html.EditorFor(model => model.Gas)
                    @Html.ValidationMessageFor(model => model.Gas, null, new { @class = "text-danger" })
                </div>
            </div>
        </div>

        <div class="form-group">
            @Html.Label(Lang["diesel"].ToString(), new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                <div class="checkbox">
                    @Html.EditorFor(model => model.Diesel)
                    <!-- No validation message here -->
                </div>
            </div>
        </div>

        <div class="form-group">
            @Html.Label(Lang["electric"].ToString(), new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                <div class="checkbox">
                    @Html.EditorFor(model => model.Electric)
                    <!-- No validation message here -->
                </div>
            </div>
        </div>

        <div class="form-group" style="margin-top:20px;">
            <div class="col-md-offset-2 col-md-10" style="display:flex; gap:12px;">
                <button type="submit" class="btn btn-primary">@Lang["edit_save"]</button>
                @Html.ActionLink(Lang["edit_back_to_list"].ToString(), "Index", null, new { @class = "btn btn-secondary" })
            </div>
        </div>

    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
