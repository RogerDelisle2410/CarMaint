@model IEnumerable<CarMaint.Models.MaintenanceType>

@{
    string lang = "en";
    if (Request.Cookies["lang"] != null)
    {
        lang = Request.Cookies["lang"].Value;
    }

    string jsonPath = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Lang", lang + ".json");
    string jsonText = System.IO.File.ReadAllText(jsonPath);
    var Lang = Newtonsoft.Json.Linq.JObject.Parse(jsonText);

    ViewBag.Title = Lang["maint_title"].ToString();
}

<h2>@Lang["maint_title"]</h2>

@using (Html.BeginForm())
{
    <p>
        @Lang["maint_find_by_task"]: @Html.TextBox("SearchString")
        <input type="submit" value="@Lang["maint_search"]" />
    </p>
}

<p>
    @Html.ActionLink(Lang["maint_create_new"].ToString(), "Create")
</p>

<head>
    <style type="text/css">
        table {
            width: 90%;
            table-layout: fixed;
        }

        td {
            border: 1px solid black;
        }

        .scrollingTable {
            width: 1150px;
            overflow-y: auto;
        }
    </style>

    <script type="text/javascript">
        function makeTableScroll() {
            var maxRows = 10;
            var table = document.getElementById('myTable');
            var wrapper = table.parentNode;
            var rowsInTable = table.rows.length;
            var height = 0;
            if (rowsInTable > maxRows) {
                for (var i = 0; i < maxRows; i++) {
                    height += table.rows[i].clientHeight;
                }
                wrapper.style.height = height + "px";
            }
        }
    </script>
</head>

<body>
    <br />
    <table id="myTable2" class="table">
        <tr>
            <th>@Lang["col_taskname"]</th>
            <th>@Lang["col_cost"]</th>
            <th>@Lang["col_gas"]</th>
            <th>@Lang["col_diesel"]</th>
            <th>@Lang["col_electric"]</th>
            <th></th>
        </tr>
    </table>
</body>

<body onload="makeTableScroll();">
    <div class="scrollingTable">
        <table id="myTable" class="table">
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.TaskName)</td>
                    <td style="text-align:right;">@string.Format("{0:c}", Convert.ToDecimal(item.Cost))</td>
                    <td style="text-align:center;">@Html.DisplayFor(modelItem => item.Gas)</td>
                    <td style="text-align:center;">@Html.DisplayFor(modelItem => item.Diesel)</td>
                    <td style="text-align:center;">@Html.DisplayFor(modelItem => item.Electric)</td>

                    <td style="text-align: center;">
                        @Html.ActionLink(Lang["btn_edit"].ToString(), "Edit", new { id = item.MaintId }) |
                        @Html.ActionLink(Lang["btn_details"].ToString(), "Details", new { id = item.MaintId }) |
                        @Html.ActionLink(Lang["btn_delete"].ToString(), "Delete", new { id = item.MaintId })
                    </td>
                </tr>
            }
        </table>
    </div>
</body>
