<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - JRD Consulting Inc.</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    @Scripts.Render("~/bundles/jquery")
    <script src="~/Scripts/help.js"></script> 
    
    @RenderSection("scripts", required: false)

    <style>
        .body-wrapper {
            padding: 5px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .home-fullscreen {
            padding: 0 !important;
            margin: 0 !important;
            height: calc(85vh - 50px);
            overflow: hidden;
        }

        /* NAVBAR ALIGNMENT FIX */
        .navbar-content {
            width: 100%;
            padding-left: 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .language-select {
            display: flex;
            align-items: center;
            gap: 15px;
        }

            .language-select label {
                display: flex;
                align-items: center;
                gap: 5px;
                cursor: pointer;
            }

        .help-button {
            background-color: #007bff; /* Bootstrap blue */
            color: white;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            border: none;
            font-size: 22px;
            font-weight: bold;
            text-align: center;
            line-height: 35px;
            cursor: pointer;
            box-shadow: 0 2px 6px rgba(0,0,0,0.25);
        }

            .help-button:hover {
                background-color: #0069d9; /* darker blue */
            }

        .help-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            z-index: 9998;
        }

        .help-content {
            background: white;
            width: 400px;
            max-width: 4000px;
            height: 250px;
            padding: 15px;
            margin: 60px auto;
            border-radius: 12px;
            text-align: left; /* ⭐ optional: looks better in narrow boxes */
            overflow-y: auto;
            /* ⭐ Force narrow wrapping */
            word-wrap: break-word;
            overflow-wrap: break-word;
            hyphens: auto;
            display: block; /* ⭐ ensures width rules apply */
        }

            .help-content p {
                width: 300px;
                margin: 0 auto;
                text-align: left;
            }

            .help-content h3 {
                margin-bottom: 20px;
                font-size: 18px;
                border-bottom: 2px solid #007bff;
                padding-bottom: 10px;
                width: 300px;
                margin-left: auto;
                margin-right: auto;
            }



        .close-help {
            margin-top: 15px;
            padding: 8px 20px;
            background: #007bff;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
        }


        .nav-controls {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-right: 50px;
        }

        .navbar-brand {
            margin-left: -10px;
        }
    </style>
</head>

<body>

    <div class="navbar navbar-inverse navbar-fixed-top">
        <div class="navbar-content">

            @{
                // Read language cookie (C# 5 compatible)
                string lang = "en";
                if (Request.Cookies["lang"] != null)
                {
                    lang = Request.Cookies["lang"].Value;
                }

                string jsonPath = Server.MapPath("~/Lang/" + lang + ".json");

                string jsonText = System.IO.File.ReadAllText(jsonPath);
                var Lang = Newtonsoft.Json.Linq.JObject.Parse(jsonText);

                var controller = ViewContext.RouteData.Values["controller"].ToString();
                var action = ViewContext.RouteData.Values["action"].ToString();

                bool isHome = controller == "Home" && action == "Index";

                // No switch expressions, no interpolation
                string navTitle = isHome ? Lang["nav_home"].ToString() : Lang["nav_menu"].ToString();


            }

            <!-- LEFT SIDE: TITLE -->
            <div class="navbar-header">
                @*@Html.ActionLink(navTitle, "Index", "Home", new { area = "" }, new { @class = "navbar-brand" })*@
                <a href="/Home/Index" class="navbar-brand">@navTitle</a>

            </div>
            <div style="color:white; font-weight:bold;">
                Controller: @controller | Action: @action
            </div>

            <!-- RIGHT SIDE: LANGUAGE + HELP -->
            <div class="nav-controls">

                <div class="language-select">
                    <label>
                        <input type="radio" name="lang" value="en" onclick="changeLang('en')" @(lang == "en" ? "checked" : "")>
                        <span id="label-en">English</span>
                    </label>

                    <label>
                        <input type="radio" name="lang" value="fr" onclick="changeLang('fr')" @(lang == "fr" ? "checked" : "")>
                        <span id="label-fr">Français</span>
                    </label>

                    <label>
                        <input type="radio" name="lang" value="es" onclick="changeLang('es')" @(lang == "es" ? "checked" : "")>
                        <span id="label-es">Español</span>
                    </label>
                </div>

                <button class="help-button" onclick="showHelp()">?</button>

                <div id="helpModal" class="help-modal">
                    <div class="help-content">
                        <h3 id="helpTitle"></h3>
                        <p id="helpText"></p>
                        <button class="close-help" onclick="closeHelp()">OK</button>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <script>
        function changeLang(lang) {
            // Save language in a cookie
            document.cookie = "lang=" + lang + "; path=/";

            // Reload page so MVC can load the correct JSON file
            location.reload();
        }
    </script>


    @if (isHome)
    {
        @RenderBody()
    }
    else
    {
        <div class="body-wrapper">
            @RenderBody()
        </div>
    } 

</body>
</html>