<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - JRD Consulting Inc.</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    @Scripts.Render("~/bundles/jquery")
    <script src="~/Scripts/help.js"></script>

    @RenderSection("scripts", required: false)

    <style>
        .body-wrapper {
            padding: 5px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .home-fullscreen {
            padding: 0 !important;
            margin: 0 !important;
            height: calc(85vh - 50px);
            overflow: hidden;
        }

        /* NAVBAR */
        .navbar-title {
            color: black !important;
            font-size: 26px;
            font-weight: bold;
            text-decoration: none;
            cursor: default;
        }

        /* LANGUAGE + HELP */
        .language-select {
            display: inline-flex;
            align-items: center;
            gap: 15px;
        }

            .language-select label {
                display: inline-flex;
                align-items: center;
                gap: 5px;
                cursor: pointer;
                font-weight: bold;
            }

        .help-button {
            background-color: #007bff;
            color: white;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            border: none;
            font-size: 22px;
            font-weight: bold;
            text-align: center;
            line-height: 35px;
            cursor: pointer;
            box-shadow: 0 2px 6px rgba(0,0,0,0.25);
            margin-left: 25px;
        }

            .help-button:hover {
                background-color: #0069d9;
            }

        /* HELP MODAL */
        .help-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            z-index: 9998;
        }

        .help-content {
            background: white;
            width: 400px;
            padding: 15px;
            margin: 60px auto;
            border-radius: 12px;
            text-align: left;
            overflow-wrap: break-word;
        }

            .help-content h3 {
                margin-bottom: 20px;
                font-size: 18px;
                border-bottom: 2px solid #007bff;
                padding-bottom: 10px;
            }

        .close-help {
            margin-top: 15px;
            padding: 8px 20px;
            background: #007bff;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
        }
    </style>
</head>

<body>

    <div class="navbar navbar-inverse navbar-fixed-top">

        @{
            string lang = "en";
            if (Request.Cookies["lang"] != null)
            {
                lang = Request.Cookies["lang"].Value;
            }

            string jsonPath = Server.MapPath("~/Lang/" + lang + ".json");
            string jsonText = System.IO.File.ReadAllText(jsonPath);
            var Lang = Newtonsoft.Json.Linq.JObject.Parse(jsonText);

            var controller = ViewContext.RouteData.Values["controller"].ToString();
            var action = ViewContext.RouteData.Values["action"].ToString();
            bool isHome = controller == "Home" && action == "Index";

            string navTitle = Lang["nav_home"].ToString();
        }

        <!-- NAVBAR: LEFT / CENTER / RIGHT -->
        <div style="width:100%; display:flex; align-items:center; padding:10px 20px;">

            <!-- LEFT -->
            <div style="flex:1; text-align:left; padding-left:50px;">
                @if (!isHome)
                {
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary">
                        @Lang["nav_menu"]
                    </a>
                }
            </div>

            <!-- CENTER -->
            <div style="flex:1; text-align:center;">
                <span class="navbar-title">@navTitle</span>
            </div>

            <!-- RIGHT -->
            <div style="flex:1; text-align:right;">
                <div class="language-select">

                    <label>
                        <input type="radio" name="lang" value="en"
                               onclick="changeLang('en')"
                               @(lang == "en" ? "checked=\"checked\"" : "") />
                        English
                    </label>

                    <label>
                        <input type="radio" name="lang" value="fr"
                               onclick="changeLang('fr')"
                               @(lang == "fr" ? "checked=\"checked\"" : "") />
                        Français
                    </label>

                    <label>
                        <input type="radio" name="lang" value="es"
                               onclick="changeLang('es')"
                               @(lang == "es" ? "checked=\"checked\"" : "") />
                        Español
                    </label>

                </div>

                <button class="help-button" onclick="showHelp()">?</button>
            </div>

        </div>

    </div>

    <!-- HELP MODAL -->
    <div id="helpModal" class="help-modal">
        <div class="help-content">
            <h3 id="helpTitle"></h3>
            <p id="helpText"></p>
            <button class="close-help" onclick="closeHelp()">OK</button>
        </div>
    </div>

    <script>
        function changeLang(lang) {
            document.cookie = "lang=" + lang + "; path=/";
            location.reload();
        }
    </script>

    @if (isHome)
    {
        @RenderBody()
    }
    else
    {
        <div class="body-wrapper">
            @RenderBody()
        </div>
    }

</body>
</html>
